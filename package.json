{
  "name": "@phoenixaihub/codebase-gpt",
  "version": "0.1.0",
  "description": "Local-first codebase intelligence — ask questions about your code, map architecture, find experts, track health.",
  "license": "MIT",
  "author": "Phoenix AI Hub",
  "homepage": "https://github.com/phoenix-assistant/codebase-gpt",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenix-assistant/codebase-gpt.git"
  },
  "keywords": ["codebase", "intelligence", "ast", "knowledge-graph", "cli", "developer-tools"],
  "bin": {
    "codebase-gpt": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "postbuild": "node -e \"const fs=require('fs'); const f='dist/cli.js'; if(fs.existsSync(f)){const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/usr/bin/env node'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);}\"",
  "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
